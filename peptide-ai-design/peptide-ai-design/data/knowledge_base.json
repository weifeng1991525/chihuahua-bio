  "peptide_design_principles": {
    "stability_optimization": [
      "N端乙酰化和C端酰胺化可显著提高抗外肽酶能力",
      "D型氨基酸替换可提高抗蛋白酶水解能力",
      "N-甲基化可降低氢键供体数量，提高膜通透性",
      "环化(头尾/侧链/二硫键)可限制构象，提高稳定性和靶点亲和力",
      "非天然氨基酸(Aib, Nle等)可提高代谢稳定性",
      "PEGylation可显著提高体内半衰期",
      "脂肪酸偶联(如棕榈酰化)可延长半衰期并促进白蛋白结合"
    ],
    "cell_permeability": [
      "阳离子多肽(富含Arg/Lys)可通过静电作用与细胞膜结合",
      "穿膜肽(CPP)如TAT、Penetratin、Pep-1等可携带货物入胞",
      "两亲性alpha-螺旋(如CPPs)可介导膜穿透",
      "N-甲基化可减少氢键供体，提高被动扩散能力",
      "环肽(如cyclosporin A)可通过被动扩散跨膜",
      "分子量<500 Da和氢键供体<5个有利于口服吸收(Lipinski规则)"
    ],
    "target_binding": [
      "alpha-螺旋模拟物(订书肽)可稳定二级结构，增强蛋白-蛋白相互作用",
      "beta-发夹模拟物可模拟天然蛋白的beta-折叠界面",
      "构象限制(环化/交联)可降低熵罚，提高结合亲和力",
      "药效团映射可优化关键残基位置",
      "丙氨酸扫描可识别关键结合残基",
      "分子对接和MD模拟可优化结合模式"
    ],
    "immunogenicity": [
      "避免已知T细胞表位(可通过IEDB数据库预测)",
      "PEGylation可降低免疫识别",
      "人源化序列设计可降低免疫原性",
      "避免重复序列和极端理化性质"
    ],
    "solubility": [
      "避免长疏水序列(>5个连续疏水氨基酸)",
      "在序列中适当引入亲水残基(Ser, Lys, Arg)",
      "C端或N端添加亲水标签(如EEE, KKK)",
      "注意等电点(pI)，避免接近生理pH",
      "避免易聚集序列(如GNNQQNY)",
      "考虑添加增溶剂(如Mini-PEG, Acp)"
    ]
  },
