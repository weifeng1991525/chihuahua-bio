{
  "peptide_synthesis_methods": {
    "solid_phase_peptide_synthesis": {
      "name_cn": "固相多肽合成 (SPPS)",
      "name_en": "Solid Phase Peptide Synthesis",
      "principle": "从C端向N端逐步偶联氨基酸，每步包含脱保护、洗涤、偶联、洗涤循环",
      "strategies": ["Fmoc策略", "Boc策略"],
      "fmoc_advantages": ["反应条件温和", "副产物少", "适用于大多数氨基酸", "易于自动化"],
      "boc_advantages": ["酸稳定性好", "适用于含酸敏感修饰的多肽"],
      "typical_yield": "70-95% (每步偶联)",
      "max_length": "通常50-60个氨基酸，长肽建议片段缩合",
      "resins": [
        {"name": "Wang Resin", "linker": "Wang", "cleavage": "TFA", "C_terminal": "游离酸"},
        {"name": "Rink Amide Resin", "linker": "Rink Amide", "cleavage": "TFA", "C_terminal": "酰胺"},
        {"name": "2-CTC Resin", "linker": "2-Chlorotrityl", "cleavage": "弱酸", "C_terminal": "游离酸，适合敏感序列"},
        {"name": "PAM Resin", "linker": "PAM", "cleavage": "HF", "C_terminal": "游离酸"}
      ],
      "coupling_reagents": [
        {"name": "HBTU/HOBt/DIEA", "efficiency": "高", "racemization": "低", "cost": "中"},
        {"name": "HATU/HOAt/DIEA", "efficiency": "极高", "racemization": "极低", "cost": "高"},
        {"name": "PyBOP/HOBt/DIEA", "efficiency": "高", "racemization": "低", "cost": "中"},
        {"name": "DIC/HOBt", "efficiency": "中高", "racemization": "低", "cost": "低"},
        {"name": "Oxyma Pure/DIC", "efficiency": "高", "racemization": "低", "cost": "中", "note": "低毒性替代HOBt"}
      ],
      "solvents": ["DMF", "NMP", "DCM"],
      "deprotection": {
        "fmoc": "20% piperidine/DMF, 2 x 5-10 min",
        "boc": "50% TFA/DCM, 15-30 min"
      },
      "cleavage": {
        "standard": "TFA/TIS/H2O (95:2.5:2.5), 2-4h, RT",
        "difficult": "TFA/TIS/EDT/H2O (92.5:2.5:2.5:2.5)",
        "note": "含Cys/Met/Trp需加清除剂防止氧化"
      }
    },
    "liquid_phase_peptide_synthesis": {
      "name_cn": "液相多肽合成 (LPPS)",
      "name_en": "Liquid Phase Peptide Synthesis",
      "principle": "溶液中逐步偶联，每步需纯化",
      "advantages": ["可大规模生产", "成本低", "无树脂限制"],
      "disadvantages": ["纯化繁琐", "不适合长肽", "自动化程度低"],
      "max_length": "通常<15个氨基酸",
      "applications": ["短肽药物", "工业级多肽", "片段合成"]
    },
    "recombinant_peptide_synthesis": {
      "name_cn": "重组表达合成",
      "name_en": "Recombinant Peptide Synthesis",
      "principle": "利用大肠杆菌/酵母/哺乳动物细胞表达",
      "advantages": ["适合长肽和蛋白", "可引入非天然氨基酸", "成本低(大规模)"],
      "disadvantages": ["不能引入化学修饰", "表达量可能低", "折叠问题"],
      "max_length": ">100个氨基酸",
      "applications": ["长肽药物", "需要正确折叠的多肽", "工业酶"]
    }
  },
